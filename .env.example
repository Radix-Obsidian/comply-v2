# Comply-v2 Environment Configuration
# Copy to .env and set values for production

# Ollama (no cloud keys needed)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:11b

# Database encryption (set a strong key for production)
DB_ENCRYPTION_KEY=

# Auth
JWT_SECRET=change-this-in-production

# Server
API_PORT=8100
CORS_ORIGINS=http://localhost:3000

# Compliance
RETENTION_DAYS=2555
PII_SCAN_ENABLED=true
AUDIT_LOG_ENABLED=true
